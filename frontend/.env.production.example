# ============================================================
# Best Cool Electronics — PRODUCTION env (Hostinger)
# Set these in hPanel → Setup Node.js App → Environment variables
# (or a .env file in the app root). NEVER commit real secrets.
# ============================================================

NODE_ENV=production

# --- Database: the MySQL DB you created in hPanel → Databases ---
# Format: mysql://USER:PASSWORD@HOST:3306/DBNAME
DATABASE_URL="mysql://u123_bestcool:STRONG_PASS@localhost:3306/u123_bestcool"

# --- Auth: signing secret for the JWT cookie (REQUIRED) ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_32_BYTES_BASE64"
# (JWT_SECRET is also accepted; NEXTAUTH_SECRET is used if JWT_SECRET is unset.)

# --- URLs ---
# APP_URL is the RUNTIME server origin — used for payment callbacks, email links,
# and Server-Component fetches. It's a plain (non-NEXT_PUBLIC) var so it's read at
# runtime and you can change the domain WITHOUT rebuilding. Set it to your live URL.
APP_URL=https://bestcoolelectronics.com
# NEXT_PUBLIC_SITE_URL is baked in at build time (client fallback only). Optional.
NEXT_PUBLIC_SITE_URL=https://bestcoolelectronics.com
# Empty = same-origin /api route handlers (this consolidated app). Leave blank.
NEXT_PUBLIC_API_URL=

# --- Cron secret: protects /api/cron/reconcile (set a Hostinger cron to hit it) ---
CRON_SECRET="CHANGE_ME_RANDOM"

# --- Courier webhook secret: couriers must present this to /api/couriers/*/webhook ---
COURIER_WEBHOOK_SECRET="CHANGE_ME_RANDOM"

# --- Email (SMTP) — fallback; Admin → Settings → Email overrides these ---
# Hostinger gives you mailboxes; use its SMTP host (e.g. smtp.hostinger.com:465).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@bestcoolelectronics.com
SMTP_PASS=
MAIL_FROM="Best Cool Electronics <no-reply@bestcoolelectronics.com>"

# --- Payments / Couriers ---
# Keep "sandbox" until you add real credentials in Admin → Settings.
# Credentials themselves are managed in the admin panel (DB), not here.
PAYMENT_MODE=sandbox
COURIER_MODE=sandbox

# --- Image uploads ---
# Default = local disk (public/uploads), which persists on Hostinger.
# To use Cloudinary instead, set these (then admin uploads go to Cloudinary):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
