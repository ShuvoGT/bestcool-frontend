// Next Mart — Prisma schema
// Covers: users/auth, catalog (products, variants, categories), reviews,
// Pages CMS (block-based), global settings, carts, wishlists, flash sales,
// orders (with courier + payment fields), delivery zones, password resets.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  CUSTOMER
}

enum PaymentMethod {
  COD
  BKASH
  NAGAD
  SSLCOMMERZ
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  COD_PENDING
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum TransactionStatus {
  INITIATED
  SUCCESS
  FAILED
  CANCELLED
}

enum CourierName {
  STEADFAST
  PATHAO
  REDX
}

// Block types supported by the Pages CMS editor.
enum BlockType {
  HERO_SLIDER
  BANNER
  RICH_TEXT
  IMAGE_TEXT
  IMAGE_GALLERY
  FEATURED_PRODUCTS
  FEATURED_CATEGORIES
  CATEGORY_PRODUCTS
  FLASH_SALE
  TESTIMONIALS
  FAQ
  CONTACT_INFO
  MAP_EMBED
}

// ---------------------------------------------------------------------------
// Users & auth
// ---------------------------------------------------------------------------

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  phone              String?
  password           String // bcrypt hash
  role               Role      @default(CUSTOMER)
  // Set true for auto-created guest-checkout accounts; forces a password
  // change on first login (spec §6).
  mustChangePassword Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  addresses           Address[]
  orders              Order[]
  cartItems           CartItem[]
  wishlistItems       WishlistItem[]
  reviews             Review[]
  passwordResetTokens PasswordResetToken[]

  @@index([phone])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String? // e.g. "Home", "Office"
  fullName  String
  phone     String
  address   String
  district  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  brand             String? // for the shop "filter by brand"
  description       String   @default("") // sanitized rich-text HTML
  sku               String?  @unique
  regularPrice      Decimal  @db.Decimal(12, 2)
  salePrice         Decimal? @db.Decimal(12, 2)
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  isActive          Boolean  @default(true)
  // Incremented on each completed order; powers "popularity" sorting.
  soldCount         Int      @default(0)
  categoryId        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category          Category           @relation(fields: [categoryId], references: [id])
  images            ProductImage[]
  variants          ProductVariant[]
  reviews           Review[]
  cartItems         CartItem[]
  wishlistItems     WishlistItem[]
  flashSaleProducts FlashSaleProduct[]
  orderItems        OrderItem[]

  @@index([categoryId])
  @@index([isActive])
  @@index([brand])
}

model ProductImage {
  id        String @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// One row per variant combination, e.g. { "Color": "Black", "Storage": "256GB" }.
model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  name       String // display name, e.g. "Black / 256GB"
  attributes Json // { attributeName: value, ... }
  sku        String?
  // Added to (or subtracted from) the product's effective price.
  priceDiff  Decimal @default(0) @db.Decimal(12, 2)
  stock      Int     @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  rating     Int // 1–5
  comment    String   @default("")
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Pages CMS & settings
// ---------------------------------------------------------------------------

model Page {
  id              String   @id @default(cuid())
  slug            String   @unique // home, about-us, contact-us, shop, showroom, terms, privacy, refund-policy
  title           String
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  blocks PageBlock[]
}

// A single content block on a page. `content` holds the block-type-specific
// payload (slides, images, text, product ids, etc.) — see backend block schemas.
model PageBlock {
  id        String    @id @default(cuid())
  pageId    String
  type      BlockType
  content   Json
  sortOrder Int       @default(0)
  isEnabled Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

// Global site settings as a key/value store (logo, menus, footer, contact,
// socials, WhatsApp, live-chat embed, Pixel/GA4 ids, SMS toggles, ...).
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// Configurable delivery methods, e.g. Inside Dhaka / Outside Dhaka.
model DeliveryZone {
  id        String  @id @default(cuid())
  name      String
  charge    Decimal @db.Decimal(12, 2)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
}

// ---------------------------------------------------------------------------
// Cart & wishlist (DB persistence for logged-in users)
// ---------------------------------------------------------------------------

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  variantId String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, variantId])
  @@index([userId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Flash sales
// ---------------------------------------------------------------------------

model FlashSale {
  id        String   @id @default(cuid())
  title     String
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products FlashSaleProduct[]

  @@index([startsAt, endsAt])
}

model FlashSaleProduct {
  id          String  @id @default(cuid())
  flashSaleId String
  productId   String
  flashPrice  Decimal @db.Decimal(12, 2)

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Overlapping-campaign protection (same product in two time-overlapping
  // campaigns) is enforced in the service layer at add time.
  @@unique([flashSaleId, productId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique // e.g. NM-000123

  userId String
  user   User   @relation(fields: [userId], references: [id])

  status        DeliveryStatus @default(PENDING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus  @default(PENDING)

  subtotal       Decimal @db.Decimal(12, 2)
  shippingCharge Decimal @db.Decimal(12, 2)
  total          Decimal @db.Decimal(12, 2)

  // Shipping snapshot (kept on the order even if the user edits their profile)
  shippingName     String
  shippingPhone    String
  shippingEmail    String
  shippingAddress  String
  shippingDistrict String
  orderNotes       String?
  deliveryZoneName String // snapshot of the chosen delivery method's name

  // Courier integration (spec §11)
  courierName       CourierName?
  consignmentId     String?
  courierStatus     String?
  courierTrackingUrl String?

  // Set when an online payment is verified server-side
  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  transactions  PaymentTransaction[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

// Price/name snapshots so historical orders survive product edits.
model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  variantId   String?
  name        String
  variantName String?
  image       String?
  // Server-resolved unit price (sale/flash-sale aware) at order time.
  unitPrice   Decimal @db.Decimal(12, 2)
  quantity    Int
  // Set when a flash-sale price was applied, for auditability.
  flashSaleId String?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// Powers the status timeline on the customer's order detail page.
model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  status    String // delivery or payment status label
  note      String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Audit trail of every gateway interaction (initiate, verify, IPN).
model PaymentTransaction {
  id                   String            @id @default(cuid())
  orderId              String
  provider             PaymentMethod
  amount               Decimal           @db.Decimal(12, 2)
  status               TransactionStatus @default(INITIATED)
  gatewayTransactionId String?
  payload              Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
