# ============================================================
# Next Mart Backend — environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development
# URL of the Next.js storefront (CORS origin)
FRONTEND_URL=http://localhost:3000
# Public URL of this API (used to build payment/courier callback URLs)
API_URL=http://localhost:5000

# --- Database ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/nextmart

# --- Auth ---
# Long random string used to sign JWTs (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-string
# JWT lifetime, e.g. 7d, 24h
JWT_EXPIRES_IN=7d

# --- Email (Nodemailer SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM="Next Mart <no-reply@nextmart.com.bd>"

# --- SMS (generic Bangladeshi HTTP gateway) ---
# Leave blank in development: SMS content is logged to console instead of sent.
SMS_API_BASE_URL=
SMS_API_KEY=
SMS_SENDER_ID=

# --- Payments ---
# sandbox | live  (controls which gateway base URLs are used)
PAYMENT_MODE=sandbox

# bKash Tokenized Checkout (PGW) — sandbox credentials from bKash merchant portal
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# Nagad merchant API — sandbox credentials from Nagad
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=
NAGAD_PG_PUBLIC_KEY=

# SSLCommerz — sandbox store from https://developer.sslcommerz.com
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=

# --- Couriers ---
# sandbox | live
COURIER_MODE=sandbox

# Steadfast (https://portal.packzy.com -> API)
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=

# Pathao Merchant API (https://merchant.pathao.com -> Developer API)
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
PATHAO_STORE_ID=

# RedX (https://redx.com.bd -> API access)
REDX_API_TOKEN=

# Shared secret couriers must send to our webhook endpoints (you define this
# value and configure it in each courier's webhook settings)
COURIER_WEBHOOK_SECRET=change-me
